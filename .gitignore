# =============================================================================
# PRISM — root .gitignore
# Keeps the judge-facing repo clean. Sub-gitignores live in app/, serve/.
# =============================================================================

# ---------------------------------------------------------------------------
# Data — raw World Bank WDI (243 MB, not for distribution; cell 4 has fallback)
# ---------------------------------------------------------------------------
data/WB_WDI_WIDEF.csv

# ---------------------------------------------------------------------------
# Environment / secrets — track only *.example variants
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
build/
develop-eggs/
eggs/
.eggs/
*.egg-info/
*.egg
sdist/
wheels/
pip-log.txt
pip-delete-this-directory.txt

# Test / coverage / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json
.coverage
.coverage.*
.cache/
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*-checkpoint.ipynb
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Node (root-level catch; app/.gitignore already covers app/)
# ---------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
*.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# ---------------------------------------------------------------------------
# R / RStudio / Rmd render artefacts (legacy analysis/R + analysis/shiny)
# ---------------------------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Rproj.user/
*.Rproj.user
*_files/
*_cache/
analysis/shiny/rsconnect/

